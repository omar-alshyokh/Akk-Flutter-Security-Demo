<?xml version="1.0" encoding="utf-8"?>
<!--
  Disable cloud backup and device-to-device transfer of app data (API 31+).
  Prevents extraction of app data via backup tooling. Combined with
  android:allowBackup="false" for older API levels.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
