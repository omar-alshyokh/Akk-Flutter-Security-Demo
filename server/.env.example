# Copy to .env and fill in.  (dotenv is NOT required — you can also export these.)

PORT=8080

# --- Play Integrity (Android) ---
# Your Android application id.
ANDROID_PACKAGE_NAME=com.smartx.fluttersecuirtydemo
# Path to a Google Cloud service-account JSON key with the Play Integrity API enabled,
# in the SAME cloud project you linked in Play Console (App integrity).
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# --- App Attest (iOS) ---
IOS_TEAM_ID=RM486MVDAU
IOS_BUNDLE_ID=com.akksec.demo.akksecflutterdemo
# Download from https://www.apple.com/certificateauthority/Apple_App_Attestation_Root_CA.pem
APPLE_APP_ATTEST_ROOT_CA=./certs/Apple_App_Attestation_Root_CA.pem
# Must match how the app was INSTALLED (not the source entitlement):
#   "development" for a build run directly from Xcode,
#   "production"  for a TestFlight or App Store install (distribution signing
#                 re-signs the app to the production App Attest environment).
APP_ATTEST_ENV=development
